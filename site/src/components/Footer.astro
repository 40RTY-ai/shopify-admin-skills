---
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Project column -->
      <div class="footer-brand">
        <h3 class="footer-name">
          Shopify Admin Skills<span class="footer-dot">.</span>
        </h3>
        <p class="footer-tagline">
          Open-source AI agent skills + scheduled routines for operating a Shopify store. MIT licensed. Built in the open.
        </p>
        <div class="footer-badges">
          <a href="https://github.com/40RTY-ai/shopify-admin-skills" target="_blank" rel="noopener" class="footer-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <span class="footer-badge footer-badge-static">MIT License</span>
          <span class="footer-badge footer-badge-static">v1.0</span>
        </div>
      </div>

      <!-- Project links -->
      <div class="footer-col" data-collapsible>
        <button class="footer-col-toggle" aria-expanded="false"><h4>Project</h4><svg class="footer-col-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
        <ul>
          <li><a href={`${base}skills/`}>All skills</a></li>
          <li><a href={`${base}routines/`}>All routines</a></li>
          <li><a href="https://github.com/40RTY-ai/shopify-admin-skills" target="_blank" rel="noopener">Source on GitHub</a></li>
          <li><a href="https://github.com/40RTY-ai/shopify-admin-skills/releases" target="_blank" rel="noopener">Releases</a></li>
        </ul>
      </div>

      <!-- Contribute -->
      <div class="footer-col" data-collapsible>
        <button class="footer-col-toggle" aria-expanded="false"><h4>Contribute</h4><svg class="footer-col-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
        <ul>
          <li><a href="https://github.com/40RTY-ai/shopify-admin-skills/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">Contributing guide</a></li>
          <li><a href="https://github.com/40RTY-ai/shopify-admin-skills/issues" target="_blank" rel="noopener">Report an issue</a></li>
          <li><a href="https://github.com/40RTY-ai/shopify-admin-skills/pulls" target="_blank" rel="noopener">Open pull requests</a></li>
          <li><a href="https://github.com/40RTY-ai/shopify-admin-skills/discussions" target="_blank" rel="noopener">Discussions</a></li>
        </ul>
      </div>

      <!-- Maintainer -->
      <div class="footer-col" data-collapsible>
        <button class="footer-col-toggle" aria-expanded="false"><h4>Maintainer</h4><svg class="footer-col-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
        <ul class="maintainer-block">
          <li class="maintainer-line">
            <a href="https://40rty.ai" target="_blank" rel="noopener" class="maintainer-link">
              <img src="/40rty-logo-small.png" alt="40rty" class="maintainer-logo" />
              <span>Maintained by <strong>40rty</strong></span>
            </a>
          </li>
          <li><a href="https://x.com/tamir_eden" target="_blank" rel="noopener">X / Twitter</a></li>
          <li><a href="mailto:contact@40rty.ai">contact@40rty.ai</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">
        <span class="footer-license">MIT License</span>
        <span class="footer-sep">·</span>
        Free to use, fork, and modify
      </p>
      <div class="footer-legal">
        <a href="https://github.com/40RTY-ai/shopify-admin-skills/blob/main/LICENSE" target="_blank" rel="noopener">License</a>
        <a href="https://github.com/40RTY-ai/shopify-admin-skills/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">Contributing</a>
        <a href="https://github.com/40RTY-ai/shopify-admin-skills" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    background: var(--color-dark);
    color: var(--color-text-light);
    margin-top: 80px;
    border-top: 1px solid rgba(250, 250, 250, 0.08);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 56px 24px 28px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  /* Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-name {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-text-light);
  }

  .footer-dot {
    color: var(--color-accent);
  }

  .footer-tagline {
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(250, 250, 250, 0.55);
    margin: 0;
    max-width: 360px;
  }

  .footer-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-light);
    background: rgba(250, 250, 250, 0.06);
    border: 1px solid rgba(250, 250, 250, 0.12);
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .footer-badge:hover {
    background: rgba(250, 250, 250, 0.12);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .footer-badge-static {
    color: rgba(250, 250, 250, 0.55);
  }

  /* Columns */
  .footer-col h4 {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(250, 250, 250, 0.55);
    margin-bottom: 16px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0;
  }

  .footer-col a {
    font-size: 0.88rem;
    color: rgba(250, 250, 250, 0.7);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-col a:hover {
    color: var(--color-text-light);
  }

  /* Maintainer */
  .maintainer-link {
    display: inline-flex !important;
    align-items: center;
    gap: 9px;
    margin-bottom: 4px;
  }

  .maintainer-logo {
    height: 22px;
    width: auto;
    filter: invert(1) brightness(1.5);
    opacity: 0.85;
  }

  .maintainer-link strong {
    color: var(--color-text-light);
    font-weight: 700;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(250, 250, 250, 0.08);
    padding-top: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(250, 250, 250, 0.5);
    margin: 0;
  }

  .footer-license {
    color: var(--color-accent);
    font-weight: 600;
  }

  .footer-sep {
    margin: 0 8px;
    color: rgba(250, 250, 250, 0.25);
  }

  .footer-legal {
    display: flex;
    gap: 22px;
  }

  .footer-legal a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(250, 250, 250, 0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-legal a:hover {
    color: var(--color-text-light);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }

  .footer-col-toggle {
    display: none;
    width: 100%;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    color: var(--color-text-light);
  }
  .footer-col-icon {
    transition: transform 0.2s;
  }
  .footer-col.is-open .footer-col-icon {
    transform: rotate(180deg);
  }

  @media (max-width: 480px) {
    .footer-col-toggle {
      display: flex;
    }
    .footer-col[data-collapsible] ul {
      display: none;
      padding-top: 8px;
    }
    .footer-col[data-collapsible].is-open ul {
      display: flex;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-collapsible] .footer-col-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const parentCol = button.parentElement;
      const isOpen = parentCol.classList.toggle('is-open');
      button.setAttribute('aria-expanded', String(isOpen));
    });
  });
</script>
