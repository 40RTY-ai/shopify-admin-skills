---
const base = import.meta.env.BASE_URL;

// Fetch GitHub star count at build time. Try GitHub API first; fall back to
// shields.io which proxies/caches the count (no rate limit). Hardcoded last-
// known value as a final fallback so the badge never renders empty.
async function fetchStars(): Promise<number | null> {
  // 1. GitHub API (rate-limited from build IPs)
  try {
    const res = await fetch('https://api.github.com/repos/40RTY-ai/shopify-admin-skills', {
      headers: { 'Accept': 'application/vnd.github+json', 'User-Agent': 'shopify-admin-skills-site' },
    });
    if (res.ok) {
      const data = await res.json();
      if (typeof data.stargazers_count === 'number') return data.stargazers_count;
    }
  } catch {}
  // 2. shields.io JSON (no auth, cached)
  try {
    const res = await fetch('https://img.shields.io/github/stars/40RTY-ai/shopify-admin-skills.json');
    if (res.ok) {
      const data = await res.json();
      const n = parseInt(data.value || data.message || '', 10);
      if (!isNaN(n)) return n;
    }
  } catch {}
  return null;
}

const stargazers = await fetchStars();
const FALLBACK_STARS = 104; // updated when build can't reach GitHub
const finalStars = stargazers ?? FALLBACK_STARS;
const starCount = finalStars >= 1000 ? `${(finalStars / 1000).toFixed(1)}k` : String(finalStars);

const navItems = [
  { name: "Skills", href: `${base}skills/` },
  { name: "Routines", href: `${base}routines/` },
  { name: "Blog", href: "https://40rty.ai/blog", external: true },
  { name: "Docs", href: "https://github.com/40RTY-ai/shopify-admin-skills#readme", external: true },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href={base} class="header-logo" aria-label="Home">
      <img src="/40rty-logo-black.png" alt="40rty" class="header-logo-img" />
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="nav-link"
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
        >
          {item.name}
          {item.external && (
            <svg class="nav-external" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          )}
        </a>
      ))}
    </nav>

    <div class="header-right">
      <a href="https://github.com/40RTY-ai/shopify-admin-skills" target="_blank" rel="noopener" class="gh-star">
        <svg class="gh-star-icon" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span class="gh-star-label">Star</span>
        <span class="gh-star-sep" data-star-loaded={starCount ? 'true' : 'false'}></span>
        <span class="gh-star-count" data-star-loaded={starCount ? 'true' : 'false'}>
          <svg class="gh-star-star" width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span id="star-num">{starCount || ''}</span>
        </span>
      </a>
      <button class="mobile-menu-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="mobile-nav">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
    <button class="mobile-menu-close" aria-label="Close navigation">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <nav>
      {navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link"
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
        >
          {item.name}
        </a>
      ))}
      <a href="https://github.com/40RTY-ai/shopify-admin-skills" target="_blank" rel="noopener" class="mobile-nav-link mobile-nav-gh">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        Star on GitHub
      </a>
    </nav>
  </div>
</header>

<style>
  /* ─── Sticky header with frosted glass on scroll ─── */
  .site-header {
    width: 100%;
    border-bottom: 1px solid transparent;
    background: transparent;
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.3s, border-color 0.3s, backdrop-filter 0.3s;
  }

  .site-header.scrolled {
    background: rgba(250, 250, 250, 0.82);
    border-bottom-color: rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(14px) saturate(1.6);
    -webkit-backdrop-filter: blur(14px) saturate(1.6);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* ─── Logo ─── */
  .header-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .header-logo:hover { opacity: 0.7; }

  .header-logo-img {
    height: 32px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* ─── Navigation ─── */
  .header-nav {
    flex: 1 1 0%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.84rem;
    font-weight: 500;
    color: rgba(10, 10, 10, 0.48);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
    letter-spacing: -0.01em;
    position: relative;
    padding: 4px 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .nav-external {
    opacity: 0;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .nav-link:hover .nav-external { opacity: 0.5; }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: var(--color-accent);
    border-radius: 1px;
    transform: scaleX(0);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center;
  }

  .nav-link:hover {
    color: var(--color-dark);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-link.is-active {
    color: var(--color-dark);
    font-weight: 600;
  }

  .nav-link.is-active::after {
    transform: scaleX(1);
    background: var(--color-dark);
  }

  /* ─── Right side ─── */
  .header-right {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ─── GitHub Star — ghost pill with pop accent bottom ─── */
  .gh-star {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    height: 34px;
    padding: 0 13px;
    background: var(--color-card);
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 600;
    border: 1.5px solid rgba(0, 0, 0, 0.08);
    border-bottom: 3px solid var(--color-accent);
    border-radius: 9px;
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: bottom;
    letter-spacing: -0.01em;
  }

  .gh-star:hover {
    border-color: rgba(0, 0, 0, 0.14);
    border-bottom-color: var(--color-accent);
    background: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
  }

  .gh-star:active {
    border-bottom-width: 1.5px;
    transform: scaleY(0.97);
    transition: all 0.06s ease;
  }

  .gh-star-icon {
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.2s;
  }

  .gh-star:hover .gh-star-icon { opacity: 0.85; }

  .gh-star-label {
    color: var(--color-dark);
  }

  .gh-star-sep {
    width: 1px;
    height: 14px;
    background: rgba(0, 0, 0, 0.1);
    flex-shrink: 0;
  }

  .gh-star-count {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }

  .gh-star-star {
    flex-shrink: 0;
  }

  /* Hide count section until loaded */
  [data-star-loaded="false"] {
    display: none;
  }

  .gh-star-count.fade-in,
  .gh-star-sep.fade-in {
    display: inline-flex;
    animation: starFadeIn 0.3s ease forwards;
  }

  @keyframes starFadeIn {
    from { opacity: 0; transform: translateX(-4px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ─── Mobile toggle ─── */
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: var(--color-dark);
    line-height: 0;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .mobile-menu-toggle:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .mobile-menu-close {
    position: absolute;
    top: 14px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: var(--color-dark);
    line-height: 0;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .mobile-menu-close:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  /* ─── Mobile nav overlay ─── */
  .mobile-nav {
    display: none;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 16px 24px 24px;
  }

  .mobile-nav nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(10, 10, 10, 0.55);
    text-decoration: none;
    padding: 10px 12px;
    border-radius: 10px;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mobile-nav-link:hover {
    color: var(--color-dark);
    background: rgba(0, 0, 0, 0.04);
  }

  .mobile-nav-gh {
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 0 0 10px 10px;
    color: rgba(10, 10, 10, 0.45);
    font-size: 0.88rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .header-inner { height: 52px; }
    .header-nav { display: none; }
    .mobile-menu-toggle { display: flex; }
    .mobile-nav.is-open { display: block; }
    .gh-star-label { display: none; }
    .gh-star-sep { display: none; }
    .gh-star { padding: 0 9px; height: 32px; gap: 5px; border-radius: 8px; }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const closeBtn = document.querySelector('.mobile-menu-close');
  const mobileNav = document.getElementById('mobile-nav');
  const header = document.querySelector('.site-header');

  let focusableElements: HTMLElement[] = [];

  function openMenu() {
    mobileNav?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    mobileNav?.setAttribute('aria-hidden', 'false');
    if (mobileNav) {
      focusableElements = Array.from(mobileNav.querySelectorAll<HTMLElement>('a, button'));
      focusableElements[0]?.focus();
    }
    document.addEventListener('keydown', trapFocus);
  }

  function closeMenu() {
    mobileNav?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    mobileNav?.setAttribute('aria-hidden', 'true');
    (toggle as HTMLElement)?.focus();
    document.removeEventListener('keydown', trapFocus);
  }

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab') return;
    const firstEl = focusableElements[0];
    const lastEl = focusableElements[focusableElements.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === firstEl) { lastEl.focus(); e.preventDefault(); }
    } else {
      if (document.activeElement === lastEl) { firstEl.focus(); e.preventDefault(); }
    }
  }

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  // Frosted glass header on scroll
  function onScroll() {
    if (window.scrollY > 8) header?.classList.add('scrolled');
    else header?.classList.remove('scrolled');
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Active nav link detection
  const currentPath = window.location.pathname;
  document.querySelectorAll<HTMLAnchorElement>('.header-nav .nav-link').forEach(link => {
    const href = link.getAttribute('href') || '';
    if (href && !link.hasAttribute('target') && currentPath.startsWith(href) && href.length > 1) {
      link.classList.add('is-active');
    }
  });

  // Client-side star count with localStorage cache (GitHub API rate-limits unauthenticated)
  const starNumEl = document.getElementById('star-num');
  const starCountEl = document.querySelector('.gh-star-count');
  const starSepEl = document.querySelector('.gh-star-sep');

  function showStarCount(text: string) {
    if (!starNumEl) return;
    starNumEl.textContent = text;
    starCountEl?.setAttribute('data-star-loaded', 'true');
    starSepEl?.setAttribute('data-star-loaded', 'true');
    // Add fade-in if wasn't visible before
    if (!starCountEl?.classList.contains('fade-in')) {
      starCountEl?.classList.add('fade-in');
      starSepEl?.classList.add('fade-in');
    }
  }

  if (starNumEl) {
    // 1. Use cached value immediately (avoids flash of empty)
    const cached = localStorage.getItem('gh-star-count');
    if (cached && !starNumEl.textContent) {
      showStarCount(cached);
    }

    // 2. Fetch fresh count. Try GitHub first, fall back to shields.io.
    const tryFetch = async (): Promise<number | null> => {
      try {
        const r = await fetch('https://api.github.com/repos/40RTY-ai/shopify-admin-skills', {
          headers: { 'Accept': 'application/vnd.github+json' },
        });
        if (r.ok) {
          const d = await r.json();
          if (typeof d.stargazers_count === 'number') return d.stargazers_count;
        }
      } catch {}
      try {
        const r = await fetch('https://img.shields.io/github/stars/40RTY-ai/shopify-admin-skills.json');
        if (r.ok) {
          const d = await r.json();
          const n = parseInt(d.value || d.message || '', 10);
          if (!isNaN(n)) return n;
        }
      } catch {}
      return null;
    };

    tryFetch().then(n => {
      if (n === null) return;
      const formatted = n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
      showStarCount(formatted);
      localStorage.setItem('gh-star-count', formatted);
    });
  }
</script>
